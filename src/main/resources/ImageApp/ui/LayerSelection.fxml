<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Slider?>

<?import javafx.scene.control.Label?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ImageApp.ui.LayerSelectionController"
      maxHeight="Infinity">

    <GridPane>
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <Label text="Opacity:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label text="Blend mode:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Slider fx:id="opacitySlider" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
        <ChoiceBox fx:id="blendmodeChoiceBox" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
    </GridPane>

    <ListView fx:id="listView" maxHeight="Infinity"/>

    <HBox>
        <Button text="+" onAction="#addLayer"/>
        <Button text="-" onAction="#deleteLayer"/>
        <Button onAction="#moveUp">
            <graphic>
                <ImageView>
                    <Image url="@../icons/layerUp-dark.png" requestedHeight="10" requestedWidth="10"/>
                </ImageView>
            </graphic>
        </Button>
        <Button onAction="#moveDown">
            <graphic>
                <ImageView>
                    <Image url="@../icons/layerDown-dark.png" requestedHeight="10" requestedWidth="10"/>
                </ImageView>
            </graphic>
        </Button>
    </HBox>
</VBox>