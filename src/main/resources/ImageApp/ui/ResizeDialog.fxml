<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.CheckBox?>

<DialogPane headerText="Resize layer" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <content>
        <GridPane>
            <Label text="Width" GridPane.rowIndex="0" GridPane.columnIndex="0" prefWidth="50"/>
            <Label text="Height" GridPane.rowIndex="1" GridPane.columnIndex="0" prefWidth="50"/>
            <TextField fx:id="fieldSizeX" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="100" text="500"/>
            <TextField fx:id="fieldSizeY" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="100" text="500"/>
            <CheckBox fx:id="checkBox" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.halignment="CENTER" text="Keep ratio"/>
        </GridPane>
    </content>
    <ButtonType fx:constant="APPLY"/>
    <ButtonType fx:constant="CLOSE"/>
</DialogPane>
