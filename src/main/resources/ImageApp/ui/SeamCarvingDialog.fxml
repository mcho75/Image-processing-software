<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.layout.VBox?>

<DialogPane headerText="Seam carving" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <content>
        <VBox spacing="10">
            <GridPane>
                <Label text="Number of seams to remove" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Slider fx:id="slider" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2" min="1"/>
                <TextField fx:id="field" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="35"/>
            </GridPane>
            <ChoiceBox fx:id="choiceBox" maxWidth="Infinity"/>
        </VBox>
    </content>
    <ButtonType fx:constant="APPLY"/>
    <ButtonType fx:constant="CANCEL"/>
</DialogPane>